NODE_ENV=development

PORT=3000

# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

DATABASE_URL="postgresql://postgres:1234@localhost:5432/pay?schema=public"

# Optional individual DB connection vars (renamed to avoid colliding with app `PORT`)
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pay

# AES-256-GCM key for encrypting API secrets (base64 or hex). Must be 32 bytes.
# Example (base64): API_SECRET_ENC_KEY=VGhpcy1Jcy1hLXNlY3JldC1rZXktMTIzNDU2Nzg=
API_SECRET_ENC_KEY=
MAX_TRANSACTION_AMOUNT=100000
TRANSACTION_EXPIRES_MINUTES=30
GLOBAL_MIN_SETTLEMENT_AMOUNT=100
SETTLEMENT_FEE=10

# Paywise gateway
PAYWISE_API_KEY=
PAYWISE_API_SECRET=
PAYWISE_WEBHOOK_SECRET=
PAYWISE_BASE_URL=https://sandbox.paywise.com
PAYWISE_MERCHANT_ID=
PAYWISE_SANDBOX_MODE=true

# App
APP_URL=http://localhost:3000

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=8h

# Super Admin (for seeding)
SUPER_ADMIN_EMAIL=admin@paycher.com
SUPER_ADMIN_PASSWORD=

# Background Jobs (Step 20)
JOBS_ENABLED=true
PAYMENT_EXPIRY_MINUTES=30
SETTLEMENT_CHECK_HOURS=48